PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/youtube_manager
JWT_SECRET=your_jwt_secret_here
YOUTUBE_API_KEY=your_youtube_api_key_here
CLIENT_URL=http://localhost:5173
# Google OAuth2 (YouTube登録チャンネル一括インポート用)
# GCP Console > API とサービス > 認証情報 > OAuth 2.0 クライアントID で取得
# 承認済みリダイレクトURIに http://localhost:3000/api/auth/google/callback を登録すること
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
